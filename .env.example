# --- CONFIGURAÇÕES DO BANCO DE DATAS ---
# Formato: mysql://usuario:senha@host:3306/nome_do_banco
DATABASE_URL="mysql://USUARIO:SENHA@localhost:3306/NOME_DO_BANCO"

# --- SEGURANÇA ---
# Gere uma frase aleatória longa para assinar os tokens de login
JWT_SECRET="COLOQUE_UMA_FRASE_LONGA_E_ALEATORIA_AQUI"

# --- INTELIGÊNCIA ARTIFICIAL (GEMINI) ---
# Pegue sua chave gratuita em: https://aistudio.google.com/
FORGE_API_KEY="SUA_CHAVE_DO_GOOGLE_GEMINI"

# --- AMBIENTE ---
NODE_ENV="production"
PORT=3000

# --- WHATSAPP (OPCIONAL) ---
# Se for usar notificações, certifique-se de que a porta do servidor está aberta
# WHATSAPP_ENABLED=true
